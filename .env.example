# taskline-server runtime config
# Copy to .env and edit. Process environment overrides .env.

# SQLite database file (parent dir is auto-created)
TASKLINE_DB=./.cache/data/taskline.db

# HTTP listen address
TASKLINE_LISTEN=:8787

# Image storage directory
TASKLINE_IMAGES_DIR=./.cache/data/images

# Markdown document storage directory
TASKLINE_DOCS_DIR=./.cache/data/docs

# Optional GitHub API token for review/done evidence checks.
# If empty, taskline-server falls back to `gh auth token`.
TASKLINE_GITHUB_TOKEN=
